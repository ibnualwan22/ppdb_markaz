generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sakan {
  id        String   @id @default(uuid())
  nama      String
  kategori  String   @default("BANIN")
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  kamar     Kamar[]
}

model Kamar {
  id         String   @id @default(uuid())
  nama       String
  sakanId    String
  isLocked   Boolean  @default(false)
  keterangan String?
  sakan      Sakan    @relation(fields: [sakanId], references: [id], onDelete: Cascade)
  lemari     Lemari[]
}

model Lemari {
  id         String         @id @default(uuid())
  nomor      String
  kamarId    String
  isLocked   Boolean        @default(false)
  isPriority Boolean        @default(false)
  keterangan String?
  kamar      Kamar          @relation(fields: [kamarId], references: [id], onDelete: Cascade)
  penghuni   RiwayatDufah[]
}

model Santri {
  id              String                 @id @default(uuid())
  nama            String
  kategori        String
  gender          String                 @default("BANIN")
  isAktif         Boolean                @default(true)
  nis             String?                @unique
  tempatLahir     String?
  tanggalLahir    DateTime?
  namaOrtu        String?
  noWaOrtu        String?
  noWaSantri      String?
  provinsi        String?
  kabupaten       String?
  kecamatan       String?
  desa            String?
  detailAlamat    String?
  batasAktifDufah Int                    @default(1)
  createdAt       DateTime               @default(now())
  expiredDufahId  Int?
  isCuti          Boolean                @default(false)
  saldoDufah      Int                    @default(0)
  riwayat         RiwayatDufah[]
  transaksi       TransaksiPendaftaran[]
}

model Dufah {
  id                   Int                    @id @default(autoincrement())
  nama                 String
  isActive             Boolean                @default(false)
  isTahunBaru          Boolean                @default(false)
  tanggalBuka          DateTime?
  tanggalTutup         DateTime?
  riwayat              RiwayatDufah[]
  transaksiPendaftaran TransaksiPendaftaran[]
}

model RiwayatDufah {
  id                   String    @id @default(uuid())
  santriId             String
  dufahId              Int
  lemariId             String?
  status               String    @default("PRE_LIST")
  isIdCardTaken        Boolean   @default(false)
  nomorIdCard          Int?
  isDresscodeTaken     Boolean   @default(false)
  ukuranDresscode      String?
  isToteBagTaken       Boolean   @default(false)
  isPinTaken           Boolean   @default(false)
  isSongkokKhimarTaken Boolean   @default(false)
  ukuranSongkok        String?
  isMalzamahTaken      Boolean   @default(false)
  isTabirotTaken       Boolean   @default(false)
  bulanKe              Int       @default(1)
  isLunas              Boolean   @default(true)
  updatedAt            DateTime  @default(now()) @updatedAt
  waktuAmbilKartu      DateTime?
  dufah                Dufah     @relation(fields: [dufahId], references: [id], onDelete: Cascade)
  lemari               Lemari?   @relation(fields: [lemariId], references: [id])
  santri               Santri    @relation(fields: [santriId], references: [id], onDelete: Cascade)

  @@unique([santriId, dufahId])
}

model User {
  id                    String                 @id @default(uuid())
  username              String                 @unique
  password              String
  nama                  String
  roleId                String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  transaksiDiverifikasi TransaksiPendaftaran[]
  role                  Role                   @relation(fields: [roleId], references: [id])
}

model Role {
  id          String           @id @default(uuid())
  nama        String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  apiKeys     ApiKey[]
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id        String           @id @default(uuid())
  namaAksi  String           @unique
  deskripsi String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  roles     RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model ApiKey {
  id          String   @id @default(uuid())
  key         String   @unique
  namaProject String
  roleId      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  role        Role     @relation(fields: [roleId], references: [id])
}

model Program {
  id                  String                 @id @default(uuid())
  nama                String
  harga               Float
  durasiBulan         Int                    @default(1)
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  tanggalMulaiDefault String?
  tanggalTutupDefault String?
  transaksi           TransaksiPendaftaran[]
}

model TransaksiPendaftaran {
  id               String    @id @default(uuid())
  noKwitansi       String    @unique
  santriId         String
  programId        String
  nominalProgram   Float
  kodeUnik         Int
  totalTagihan     Float
  statusPembayaran String    @default("PENDING")
  diverifikasiOleh String?
  createdAt        DateTime  @default(now())
  waktuLunas       DateTime?
  dufahTujuanId    Int?
  admin            User?     @relation(fields: [diverifikasiOleh], references: [id])
  dufahTujuan      Dufah?    @relation(fields: [dufahTujuanId], references: [id], onDelete: SetNull)
  program          Program   @relation(fields: [programId], references: [id])
  santri           Santri    @relation(fields: [santriId], references: [id], onDelete: Cascade)
}

model Notification {
  id                 String   @id @default(uuid())
  title              String
  message            String
  link               String?
  permissionRequired String
  createdAt          DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  aksi      String
  modul     String
  deskripsi String
  userId    String?
  namaUser  String
  targetId  String?
  metadata  String?
  createdAt DateTime @default(now())
}

model Pengajar {
  id          String   @id @default(uuid())
  nama        String
  foto        String?
  trackRecord String[] @default([])
  urutan      Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
